<?xml version="1.0" encoding="UTF-8"?>
<entity-mappings xmlns="https://jakarta.ee/xml/ns/persistence/orm"
                 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence/orm
                   https://jakarta.ee/xml/ns/persistence/orm/orm_3_2.xsd"
                 version="3.2">

  <named-native-query name="ShowDetailView.getShow" result-set-mapping="ShowDetailView">
    <query>
      SELECT s.show_id,
      s.scheduled_at,
      s.movie_id,
      s.movie_title,
      s.movie_runtime_minutes,
      s.hall_id,
      s.hall_name,
      s.hall_seat_count
      FROM show s
      WHERE s.show_id = :show_id
    </query>
  </named-native-query>

  <named-native-query name="ShowSummaryView.listShows" result-set-mapping="ShowSummaryView">
    <query>
      SELECT s.show_id,
      s.scheduled_at,
      s.movie_title,
      s.hall_name
      FROM show s
      ORDER BY s.scheduled_at
      OFFSET :offset ROWS FETCH NEXT :limit ROWS ONLY
    </query>
  </named-native-query>

  <sql-result-set-mapping name="ShowDetailView">
    <constructor-result target-class="com.github.scheduling.application.show.query.ShowDetailView">
      <column name="show_id" class="java.lang.String"/>
      <column name="scheduled_at" class="java.time.Instant"/>
      <column name="movie_id" class="java.lang.String"/>
      <column name="movie_title" class="java.lang.String"/>
      <column name="movie_runtime_minutes" class="java.lang.Integer"/>
      <column name="hall_id" class="java.lang.String"/>
      <column name="hall_name" class="java.lang.String"/>
      <column name="hall_seat_count" class="java.lang.Integer"/>
    </constructor-result>
  </sql-result-set-mapping>

  <sql-result-set-mapping name="ShowSummaryView">
    <constructor-result target-class="com.github.scheduling.application.show.query.ShowSummaryView">
      <column name="show_id" class="java.lang.String"/>
      <column name="scheduled_at" class="java.time.Instant"/>
      <column name="movie_title" class="java.lang.String"/>
      <column name="hall_name" class="java.lang.String"/>
    </constructor-result>
  </sql-result-set-mapping>

</entity-mappings>
