<?xml version="1.0" encoding="UTF-8" ?>
<entity-mappings xmlns="https://jakarta.ee/xml/ns/persistence/orm" version="3.2">
  <named-native-query name="Booking.getBooking" result-set-mapping="GetBooking.Booking">
    <query>
      <![CDATA[
        SELECT
          b.booking_id,
          b.status,
          bs.show_id AS show_id,
          bs.scheduled_at AS show_scheduled_at
        FROM
          booking AS b
        INNER JOIN
          show AS bs ON bs.show_id = b.show_id
        WHERE
          b.booking_id = :booking_id
      ]]>
    </query>
  </named-native-query>
  <named-native-query name="Booking.listBookings" result-set-mapping="ListBookings.Booking">
    <query>
      <![CDATA[
        SELECT
          b.booking_id,
          b.status,
          bs.show_id AS show_id,
          bs.scheduled_at AS show_scheduled_at
        FROM
          booking AS b
        INNER JOIN
          show AS bs ON bs.show_id = b.show_id
        ORDER BY
          b.id_ ASC
        OFFSET :offset
        FETCH NEXT :limit ROWS ONLY
      ]]>
    </query>
  </named-native-query>
  <sql-result-set-mapping name="GetBooking.Booking">
    <constructor-result target-class="com.github.booking.application.booking.query.GetBooking$Booking">
      <column name="booking_id"/>
      <column name="status"/>
      <column name="show_id"/>
      <column name="show_scheduled_at" class="java.time.Instant"/>
    </constructor-result>
  </sql-result-set-mapping>
  <sql-result-set-mapping name="ListBookings.Booking">
    <constructor-result target-class="com.github.booking.application.booking.query.ListBookings$Booking">
      <column name="booking_id"/>
      <column name="status"/>
      <column name="show_id"/>
      <column name="show_scheduled_at" class="java.time.Instant"/>
    </constructor-result>
  </sql-result-set-mapping>
</entity-mappings>
